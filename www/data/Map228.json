":0,"parameters":["「……真没想到妳人还挺好的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[013]"]},{"code":401,"indent":0,"parameters":["「没想到是多余的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[014]"]},{"code":401,"indent":0,"parameters":["「还有，谢谢你白天帮了日和的忙。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「这个嘛……对方不想做，我也不能强迫她吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[015]"]},{"code":401,"indent":0,"parameters":["「但是一般的男人都会出手啊。"]},{"code":401,"indent":0,"parameters":["  你人也挺好的嘛。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「还好啦。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 43"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[045]"]},{"code":401,"indent":0,"parameters":["「我倒觉得硬上我也没关系呀。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳多多珍惜一下日和吧……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[016]"]},{"code":401,"indent":0,"parameters":["「事情就是这样，艾莲娜也要一起去。"]},{"code":401,"indent":0,"parameters":["  请多指教。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「没问题吧……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[017]"]},{"code":401,"indent":0,"parameters":["「还有，我总觉得很在意你。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[018]"]},{"code":401,"indent":0,"parameters":["「没有啦，我也不是喜欢你，"]},{"code":401,"indent":0,"parameters":["  只是觉得不能放着你不管……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这也是轮回的影响吗？"]},{"code":401,"indent":0,"parameters":["  毕竟上一次我和她相处得很好。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我知道了。战力增加我也很高兴。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[019]"]},{"code":401,"indent":0,"parameters":["「嗯，恢复就交给我吧！」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 31"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[046]"]},{"code":401,"indent":0,"parameters":["「那么接下来，我们要潜入霍夫曼的工坊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「工坊……有这种地方啊？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[047]"]},{"code":401,"indent":0,"parameters":["「学院提供了一部分老师研究魔法的设施。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 31"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[048]"]},{"code":401,"indent":0,"parameters":["「霍夫曼也是其中一人。」"]},{"code":101,"indent":0,"parameters
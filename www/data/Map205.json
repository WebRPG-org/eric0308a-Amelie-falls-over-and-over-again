code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[084]"]},{"code":401,"indent":0,"parameters":["「要是勃起的话，你就要陪艾莲娜做到满意为止啰。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【班上的辣妹】"]},{"code":401,"indent":0,"parameters":["「哪边都赚呢，啊哈哈……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[085]"]},{"code":401,"indent":0,"parameters":["「我的胸部应该比艾蜜莉大喔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这种事……怎么可能忍住。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[086]"]},{"code":401,"indent":0,"parameters":["「呵呵，一瞬间就硬起来了啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咕……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[087]"]},{"code":401,"indent":0,"parameters":["「不过大小不怎么样呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【其他班的辣妹】"]},{"code":401,"indent":0,"parameters":["「毕竟我们看习惯杰克森学长的肉棒啦～」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"inden
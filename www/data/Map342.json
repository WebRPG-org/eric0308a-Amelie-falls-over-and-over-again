indent":0,"parameters":["  「在与恶魔的战斗中，有时会集合十几名魔法使，"]},{"code":401,"indent":0,"parameters":["  使用仪式魔法从远距离攻击据点。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 5"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「啊～好想要使魔喔～」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「怎么忽然说这个？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「我看见前辈拿猫头鹰当使魔，"]},{"code":401,"indent":0,"parameters":["  所以我也想要一只。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「原来如此。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「猫头鹰果然是经典啊。"]},{"code":401,"indent":0,"parameters":["  我要不要也订个契约呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「然后让它从空中带信给我。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「原来不是为了战斗啊……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「感觉很可爱嘛。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「那正常当作宠物不就好了？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「再说，照顾猫头鹰可是很麻烦的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「咦，是喔？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「尤其是饲料。要喂它新鲜的老鼠或是虫子才行。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 13"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「咦！这种事我不行啦。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「老鼠和虫子都很恶心，我一点也不想摸。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「那就没办法了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「呿……那你不想要使魔吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「我想想……要订契约的话果然还是选黑猫吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【艾莲娜】"]},{"code":401,"indent":0,"parameters":["  「真没意思。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「有什么关系。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「猫很可爱，能够疗愈人心啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 13"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":40
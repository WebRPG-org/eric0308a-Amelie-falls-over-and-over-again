null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":41,"parameters":["",0],"indent":null}]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":22,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":22,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「偶尔会出现很有钱的女孩子，"]},{"code":401,"indent":0,"parameters":["  那好像都是卖淫赚来的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「咦，是这样吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「嗯，听说学院好像有在取缔，"]},{"code":401,"indent":0,"parameters":["  不过似乎很难抓到。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「因为老师和学生会一来，他们就会躲起来。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「哦……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「是在社团楼层拉客的喔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「我又没有兴趣。而且我也没什么钱。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「你是赚钱的那边啊？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「那怎么可能。再说也没有女孩子愿意出钱吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「我的话倒是有呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「原来你有在做啊！」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「只是偶尔而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「真是的……这所学院还真是为所欲为。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「啊哈哈，你有兴趣的话就去拜托看看艾莲娜吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「咦？艾莲娜也有做吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「以前有啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「是吗……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「你喜欢她吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「我、我才没有喜欢她……"]},{"code":401,"indent":0,"parameters":["  只是，我曾经觉得她像猫的地方很棒。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「又是动物话题啊……不过她像猫吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「像是自由奔放的个性……还有凤眼之类的……"]},{"code":401,"indent":0,"parameters":["  不是啦，我才没有喜欢她。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「处男般的反应真可爱。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameter
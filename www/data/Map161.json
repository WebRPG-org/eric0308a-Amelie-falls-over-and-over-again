2,"parameters":["終わり"]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"否"]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":204,"indent":0,"parameters":[8,4,4]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「呃～我是教授仪式学的梅丽莎。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「巧合的是2-A班的学生很多，所以自我介绍就跳过吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「那我要开始上课了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（明明还有别班的学生在，这样没问题吗……？）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「正宗选修了仪式学啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊，因为我没有学过大规模魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（其实我只是想收集上次轮回时进行的仪式情报。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（要是能知道吸收魔力的仪式魔法就好了。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「话说汤米也选仪式学啊。」"]},{"code":213,"indent":0,"parameters":[3,3,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「嗯。其实我选哪一堂都行，"]},{"code":401,"indent":0,"parameters":["  所以就和正宗选同一堂了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（真可爱……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「我想你应该也还没习惯学院。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「帮大忙了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（因为我和上次轮回采取了不同的行动，"]},{"code":401,"indent":0,"parameters":["  所以其他人的行动也改变了吗？）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这样的话，似乎不太能活用上次的经验。）」"]},{"code":213,"indent":0,"parameters":[4,4,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莱昂】"]},{"code":401,"indent":0,"parameters":["「我也在喔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「谢谢喔。不过你其实是跟着艾蜜莉来的吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莱昂】"]},{"code":401,"indent":0,"parameters":["「是啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这家伙真是意志坚定。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[000]"]},{"code":401,"indent":0,"parameters":["「莱昂，你会不会太缠着艾蜜莉啦？　"]},{"code":401,"indent":0,"parameters":["  会给她添麻烦吧？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":356,"indent":0,"parameters":["スキット スライドイン アメリ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"inden
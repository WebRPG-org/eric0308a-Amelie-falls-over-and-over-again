parameters":["スキット 表情 エレナ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[006]"]},{"code":401,"indent":0,"parameters":["「好～」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「仪式魔法当中最知名的就是召唤恶魔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「恶魔基本上都是透过仪式魔法，"]},{"code":401,"indent":0,"parameters":["  从地狱被召唤到地表上的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「而力量越强大的恶魔，"]},{"code":401,"indent":0,"parameters":["  仪式就要求更多的魔力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「为了召唤恶魔而抓捕人类的事件，"]},{"code":401,"indent":0,"parameters":["  你们应该也知道吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「召唤仪式也是一种魔法。也就是说，"]},{"code":401,"indent":0,"parameters":["  人类也能够召唤恶魔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莱昂】"]},{"code":401,"indent":0,"parameters":["「会有人做这种事吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「过去曾有过案例。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「不过，这当然是禁忌。"]},{"code":401,"indent":0,"parameters":["  召唤恶魔的人有一半都被关起来了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[007]"]},{"code":401,"indent":0,"parameters":["「只有一半？明明是禁忌啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「因为另外一半都被召唤出来的恶魔杀害了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[008]"]},{"code":401,"indent":0,"parameters":["「咿……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「就算是自己召唤出来的，"]},{"code":401,"indent":0,"parameters":["  也不代表订下了契约。」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「也就是说，召唤出来的恶魔不一定会听从指示。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「在这个层面上来说，召唤魔法也被视为一种禁忌。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「不过，召唤魔法需要庞大的魔力对吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「靠人类的魔力办得到吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「办不到。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「人类来召唤的话，就会需要另一种仪式魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「就是聚集魔力的仪式魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（聚集魔力……难道这就是？）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「有聚集参加者魔力的仪式，"]},{"code":401,"indent":0,"parameters":["  还有收集周遭魔力的仪式等各式各样。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「收集周遭魔力的仪式是什么？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 11"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[009]"]},{"code":401,"indent":0,"parameters":["「你是怎样，你想召唤恶魔吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン アメリ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[016]"]},{"code":401,"indent":0,"parameters":["「正宗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那怎么可能！艾蜜莉也别搞错了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[17]\\z[010]"]},{"code":401,"indent":0,"parameters":["「可是你看起来很有兴趣啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我只是在认真上课而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「别开玩笑了，枫丹。」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「但是我不会教你们收集魔力的仪式。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"inden
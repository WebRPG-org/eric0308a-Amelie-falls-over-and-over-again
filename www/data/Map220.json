2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「各位知道诅咒魔法主要分为两种对吧。"]},{"code":401,"indent":0,"parameters":["  阿马多尔，你来回答。」"]},{"code":204,"indent":0,"parameters":[2,3,4]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 3"]},{"code":356,"indent":0,"parameters":["スキット スライドイン レオン f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莱昂】"]},{"code":401,"indent":0,"parameters":["「我不知道。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（回答得真干脆。）」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「……布兰琪妳知道吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン アメリ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[8]\\z[004]"]},{"code":401,"indent":0,"parameters":["「是，分为共感魔法和传染魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「没错。共感魔法利用的是相似的事物会互相影响的法则。」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「举例来说，有一种魔法，"]},{"code":401,"indent":0,"parameters":["  只要对模仿人类形状的人偶施加伤害，就能攻击到本人。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「传染魔法则具有曾经接触过的事物，"]},{"code":401,"indent":0,"parameters":["  或者原本是一体的事物，即使分开也会受到影响的性质。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「像是使用人类的头发和指甲，"]},{"code":401,"indent":0,"parameters":["  对本人造成影响的魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「顺带一提，姓名也包含在内。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【霍夫曼老师】"]},{"code":401,"indent":0,"parameters":["「所以有很多魔法使会隐藏本名。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 2"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 右2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[001]"]},{"code":401,"indent":0,"parameters":["「唉。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[002]"]},{"code":401,"indent":0,"parameters":["「正宗你没有学过魔法对吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[003]"]},{"code":401,"indent":0,"parameters":["「你能够跟上课程吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[004]"]},{"code":401,"indent":0,"parameters":["「因为这门课，是以一年级时学过基础为前提啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「啊、啊……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（她怎么这么亲切！）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（妳怎么了啊艾莲娜。"]},{"code":401,"indent":0,"parameters":["  来嘲讽我的老二啊。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[005]"]},{"code":401,"indent":0,"parameters":["「你干嘛一脸奇怪的表情。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「没有，没什么啦。"]},{"code":401,"indent":0,"parameters":["  但基本知识我还是懂的，目前没什么问题。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[21]\\z[006]"]},{"code":401,"indent":0,"parameters":["「是吗。」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（难道说前几次轮回发生的事情，"]},{"code":401,"indent":0,"parameters":["  影响到她了吗……？）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（受到影响的人，或许不只有艾蜜莉。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「日和跟我是同乡对吧，我们好好相处吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 2"]},{"code":356,"indent":0,"parameters":["スキット スライドイン 日和 f 左"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[30]\\z[001]"]},{"code":401,"indent":0,"parameters":["「嗯，我也要请你多多指教。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我记得妳是学生会的对吧？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[30]\\z[002]"]},{"code":401,"indent":0,"parameters":["「是啊……我有跟你说过吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「啊……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这个时间点我还不知道啊。"]},{"code":401,"indent":0,"parameters":["  糟糕……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「没有啦，我是听汤米说的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[30]\\z[003]"]},{"code":401,"indent":0,"parameters":["「原来是这样啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「二年级就加入学生会，这不是很厉害吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[30]\\z[004]"]},{"code":401,"indent":0,"parameters":["「没这回事啦。"]},{"code":401,"indent":0,"parameters":["  虽然学生会里只有我是二年级的，"]},{"code":401,"indent":0,"parameters":["  但只是因为没有人想加入而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「原来是这样……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[30]\\z[005]"]},{"code":401,"indent":0,"parameters":["「毕竟要办的杂事很多。"]},{"code":401,"indent":0,"parameters":["  难道说正宗同学对学生会有兴趣吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「不，我没有兴趣。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"c
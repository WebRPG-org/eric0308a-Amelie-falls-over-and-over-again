rameters":["\\>【艾蜜莉】\\m[3]\\z[082]"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「艾蜜莉……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【男学生】"]},{"code":401,"indent":0,"parameters":["「嘿嘿……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[083]"]},{"code":401,"indent":0,"parameters":["「正宗，你没事真是太好了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我怎样都无所谓。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（为什么全裸啊……发生什么事了……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「你做了什么好事……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 2"]},{"code":356,"indent":0,"parameters":["スキット スライドイン ジャクソン f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「那当然是做了很多好事啰。哈哈……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咕……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「不过你也有错啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「艾蜜莉为了不让我们对你出手，"]},{"code":401,"indent":0,"parameters":["  挺身保护你呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……艾蜜莉，妳根本不用管我啊……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[084]"]},{"code":401,"indent":0,"parameters":["「那怎么行，我是你的大姐姐啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「可恶……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「不过，我们现在也可以教训你一下。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[085]"]},{"code":401,"indent":0,"parameters":["「住手……我们说好了吧？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「那是过去的事了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「这家伙不知为何知道了计画的事情，"]},{"code":401,"indent":0,"parameters":["  所以不能放着他不管。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[086]"]},{"code":401,"indent":0,"parameters":["「求求你……不要对正宗出手。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「不用担心我。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[087]"]},{"code":401,"indent":0,"parameters":["「怎么会不担心啊……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「艾蜜莉……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「真是令人羡慕的关系啊。看见这样的互动，"]},{"code":401,"indent":0,"parameters":["  就让人想要破坏掉呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「喂，妳在这里道歉吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[088]"]},{"code":401,"indent":0,"parameters":["「道歉是指……？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「为妳妨碍我们的计画而道歉。"]},{"code":401,"indent":0,"parameters":["  这样我就不对他出手。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[3]\\z[089]"]},{"code":401,"indent":0,"parameters":["「我知道了，如果这样你就愿意原谅我们的话。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（不行啊……我明明不希望发生这种事。）」"]},{"code":117,"indent":0,"parameters":[173]},{"code":221,"indent":0,"parameters":[]},{"code":211,"indent":0,"parameters":[1]},{"code":121,"indent":0,"parameters":[15,15,1]},{"code":201,"indent":0,"parameters":[1,35,4,5,0,0]},{"code":117,"indent":0,"parameters":[148]},{"code":117,"indent":0,"parameters":[3]},{"code":222,"indent":0,"pa
ers":["  我知道你们在这里做什么。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「我们又没做什么会被逮捕的事情。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【学长Ａ】"]},{"code":401,"indent":0,"parameters":["「是啊，不过倒是有做会让女孩子高兴的事情呢。"]},{"code":401,"indent":0,"parameters":["  哈哈。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[42]\\z[020]"]},{"code":401,"indent":0,"parameters":["「虽然学院允许一定程度的自由，"]},{"code":401,"indent":0,"parameters":["  但是经营风俗店当然是不行的吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[42]\\z[021]"]},{"code":401,"indent":0,"parameters":["「乖乖把店收了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[42]\\z[022]"]},{"code":401,"indent":0,"parameters":["「主犯杰克森要去反省室。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「那还真是伤脑筋啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[42]\\z[023]"]},{"code":401,"indent":0,"parameters":["「再说，恶魔召唤仪式的事情你还没有反省啊？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「我有啊。魔法研暂停活动真的很伤脑筋呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters"
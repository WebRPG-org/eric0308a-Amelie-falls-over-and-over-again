"indent":0,"parameters":["",0,0,1]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["有人批评他们违背了神明的教诲，"]},{"code":401,"indent":0,"parameters":["有人说应该将他们关进大牢。"]},{"code":101,"indent":0,"parameters":["",0,0,1]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["人们将这些人称为魔法使。"]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「我希望你们前往卡雷德尼魔法学院，"]},{"code":401,"indent":0,"parameters":["  进行潜入调查。」"]},{"code":213,"indent":0,"parameters":[3,1,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「忽然找我们到王立陆军的本部来，"]},{"code":401,"indent":0,"parameters":["  我还以为要说什么呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「别这么说嘛。这个任务也是为了你们好。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「魔法使不受世人待见，"]},{"code":401,"indent":0,"parameters":["  这点你们也很清楚吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン アメリ t 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[002]"]},{"code":401,"indent":0,"parameters":["「是。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「虽然说我们和恶魔一样用魔法战斗，"]},{"code":401,"indent":0,"parameters":["  但我们也是为了人类而战啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「世人对恶魔就是有如此深刻的憎恨。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[003]"]},{"code":401,"indent":0,"parameters":["「这点我们也是一样。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「我明白。所以我才会在以勇者组成的王立陆军当中，"]},{"code":401,"indent":0,"parameters":["  创立一支魔法使的部队啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「但是所属于王立陆军的我们，"]},{"code":401,"indent":0,"parameters":["  居然要潜入卡雷德尼魔法学院……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「魔法使和王国之间的关系一直在恶化。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「如果被发现是王立陆军的间谍，"]},{"code":401,"indent":0,"parameters":["  肯定会演变成麻烦的局面。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「既然这样……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「但是，最近有流言传出，"]},{"code":401,"indent":0,"parameters":["  卡雷德尼魔法学院里正在进行恶魔的召唤仪式。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[004]"]},{"code":401,"indent":0,"parameters":["「召唤恶魔……那么应该立刻派出王立陆军的部队吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「目前还只是流言而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「我只是从认识的商人那里，得知了召唤仪式"]},{"code":401,"indent":0,"parameters":["  相关的魔法道具被运送到学院的消息而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「即使是王立陆军，"]},{"code":401,"indent":0,"parameters":["  也没办法仅凭这点程度的消息就去调查魔法学院。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[005]"]},{"code":401,"indent":0,"parameters":["「所以才要由身为魔法使的我们，"]},{"code":401,"indent":0,"parameters":["  来进行潜入调查啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「是啊，你们两位的年纪就算当学生也不奇怪，"]},{"code":401,"indent":0,"parameters":["  没有比你们更适合的人选了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「这个任务也是为了魔法使好。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「如果恶魔真的被召唤至卡雷德尼魔法学院，"]},{"code":401,"indent":0,"parameters":["  那么对于魔法使的批评会变得更加严厉吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「不知道召唤恶魔是为了什么原因，"]},{"code":401,"indent":0,"parameters":["  但是必须事先阻止才行。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「我认为与恶魔战斗时"]},{"code":401,"indent":0,"parameters":["  魔法使将会成为重要的战力。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[006]"]},{"code":401,"indent":0,"parameters":["「少校……我知道了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我们一开始就没有拒绝的权利啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[007]"]},{"code":401,"indent":0,"parameters":["「正宗，别说这种话。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[008]"]},{"code":401,"indent":0,"parameters":["「为了继续存在，魔法部队必须留下成果才行。"]},{"code":401,"indent":0,"parameters":["  所以接到重要的任务是值得高兴的事情啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我知道。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「转学手续等等就由我这边处理。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【卡本特少校】"]},{"code":401,"indent":0,"parameters":["「那么，祝两位奋斗顺利。」"]},{"code":230,"indent":0,"parameters":[30]},{"code":242,"indent":0,"parameters":[1]},{"code":221,"indent":0,"parameters":[]},{"code":319,"indent":0,"parameters":[2,2,9]},{"code":211,"indent":0,"parameters":[1]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":223,"indent":0,"parameters":[[0,0,0,0],1,true]},{"code":201,"indent":0,"parameters":[0,9,19,43,8,0]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":4,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":222,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":21,"y":16},null,{"id":3,"name":"まさ","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"7_1","direc
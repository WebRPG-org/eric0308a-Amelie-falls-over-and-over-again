,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「我有事情想拜托你们。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン 日和 f 右2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[31]\\z[000]"]},{"code":401,"indent":0,"parameters":["「是什么事呢？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「虽然有点难以启齿……"]},{"code":401,"indent":0,"parameters":["  但我想拜托你们指导国中部的学生。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是可以啦……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这也不是什么难以启齿的事情吧。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「那真是帮大忙了。顺带一提，内容是关于性行为。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[31]\\z[001]"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「性行为是指……？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「简单来说，我希望你们教国中部的男学生做爱。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这间学院……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["「这是上面的命令。我也不想拜托你们这种事。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"i
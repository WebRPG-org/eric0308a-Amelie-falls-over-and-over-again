 f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[465]"]},{"code":401,"indent":0,"parameters":["「那就好……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 19"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[466]"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[467]"]},{"code":401,"indent":0,"parameters":["「唉……课程好像还没有要重新开始，"]},{"code":401,"indent":0,"parameters":["  要不要再两人独处一下呢？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯，当然没问题。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 19"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[468]"]},{"code":401,"indent":0,"parameters":["「那就去交谊室的那里吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（她是说宾馆吧……）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[469]"]},{"code":401,"indent":0,"parameters":["「你不想去吗……？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我可以啊……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[470]"]},{"code":401,"indent":0,"parameters":["「那就没问题了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":10
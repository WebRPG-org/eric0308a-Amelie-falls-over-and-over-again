eters":["  真是时光飞逝呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我倒是过了很长一段时间呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[448]"]},{"code":401,"indent":0,"parameters":["「是啊……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[449]"]},{"code":401,"indent":0,"parameters":["「莉薇坦的魔力怎么样了？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「好像没有什么特别的变化。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「毕竟我得到的魔力没有汤米那么多。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「但是，可能会被魔法协会发现。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[450]"]},{"code":401,"indent":0,"parameters":["「嗯……但是你是为了我而行动的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[451]"]},{"code":401,"indent":0,"parameters":["「所以我会尽全力袒护你，放心吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[452]"]},{"code":401,"indent":0,"parameters":["「说不定能够以特例对你网开一面呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[453]"]},{"code":401,"indent":0,"parameters":["「毕竟他们肯定也想研究王的魔力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「如果是这样就好了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「但是就算现在被关进牢里，我也不会后悔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「因为我已经成功守护妳了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[454]"]},{"code":401,"indent":0,"parameters":["「嗯……真的很谢谢你。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[455]"]},{"code":401,"indent":0,"parameters":["「现在的正宗很可靠呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 19"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[456]"]},{"code":401,"indent":0,"parameters":["「感觉好像很帅气呢……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「很帅气……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（好高兴……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「现在……妳还喜欢我吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[457]"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[458]"]},{"code":401,"indent":0,"par
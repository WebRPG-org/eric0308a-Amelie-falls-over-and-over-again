rameters":[0,1,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「哇！」"]},{"code":213,"indent":0,"parameters":[-1,1,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「啊！」"]},{"code":250,"indent":0,"parameters":[{"name":"Jump1","volume":90,"pitch":100,"pan":0}]},{"code":205,"indent":0,"parameters":[0,{"list":[{"code":14,"parameters":[0,0],"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":14,"parameters":[0,0],"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「谁、谁啊！？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我是今天转学过来，"]},{"code":401,"indent":0,"parameters":["  入住宿舍的香心正宗。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「老师没告诉你吗？」"]},{"code":213,"indent":0,"parameters":[0,8,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「…………」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「啊，这么说来老师有说过……"]},{"code":401,"indent":0,"parameters":["  原来是今天入住啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么事……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「唉嘿嘿，抱歉抱歉。」"]},{"code":205,"indent":0,"parameters":[0,{"list":[{"code":1,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":1,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「我是汤米・戴温。"]},{"code":401,"indent":0,"parameters":["  以后就是室友了，叫我汤米就行了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯，汤米。以后请多多指教。"]},{"code":401,"indent":0,"parameters":["  你也叫我正宗就行了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「嗯，请多指教啰，正宗。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（他是……男生吧。"]},{"code":401,"indent":0,"parameters":["  他的外表比较中性，害我有点吓到。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（要快点习惯集体生活才行。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「本来应该由宿舍长来介绍宿舍的，"]},{"code":401,"indent":0,"parameters":["  但是他因为生病正在休养。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「所以宿舍长拜托我代为介绍。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「啊，所谓的宿舍长，"]},{"code":401,"indent":0,"parameters":["  指的是在宿舍提供生活协助的资深老师喔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「原来如此。我是皇国出身的，"]},{"code":401,"indent":0,"parameters":["  你这么详细地告诉我真是帮大忙了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「皇国……你从很远的地方过来呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「不过同学里也有皇国出身的人，"]},{"code":401,"indent":0,"parameters":["  别担心。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那还真是令人安心。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「总之，有什么想问的就问吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「之后我再带你看看宿舍。」"]},{"code":117,"indent":0,"parameters":[3]},{"code":122,"indent":0,"parameters":[1,1,0,0,9]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":true,"variableValue":9},"directionFix":false,"image":{"tileId":0,"characterName":"7_6","direction":2,"pattern":1,"characterIndex":2},"list":[{"code":118,"indent":0,"parameters":["01"]},{"code":102,"indent":0,"parameters":[["关于霍华德宿舍","关于卡雷德尼魔法学院","关于课程","关于社团","没问题了"],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"关于霍华德宿舍"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「卡雷德尼魔法学院是全住宿制的学校。"]},{"code":401,"indent":1,"parameters":["  除了长假以外，基本上都是在宿舍生活。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「宿舍一共分成三间，分别是霍华德宿舍、"]},{"code":401,"indent":1,"parameters":["  贝利宿舍和克拉克宿舍。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「名字取自于第一位宿舍长，"]},{"code":401,"indent":1,"parameters":["  各个宿舍之间没什么差异。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「正宗入住的是霍华德宿舍喔。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「宿舍就位于校舍最上层的六楼。"]},{"code":401,"indent":1,"parameters":["  所以上学也非常方便。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「事情就是这样，我们要在同一间房住到毕业，"]},{"code":401,"indent":1,"parameters":["  所以好好相处吧！」"]},{"code":119,"indent":1,"parameters":["01"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"关于卡雷德尼魔法学院"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「来自皇国的话，可能会觉得比较陌生。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「因为我是在古德兰王国长大的，"]},{"code":401,"indent":1,"parameters":["  所以自从发现魔法才能之后，"]},{"code":401,"indent":1,"parameters":["  就一直想要进入学院就读。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「这里是历史最悠久的魔法学院，"]},{"code":401,"indent":1,"parameters":["  来自世界各地的学生都聚集在这里。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「当然，入学时有很严格的考试，"]},{"code":401,"indent":1,"parameters":["  如果没有魔法天分就无法入学呢。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「而且学费也很高，如果不是「Upper middle class」……"]},{"code":401,"indent":1,"parameters":["  这个，位于上层中产阶级以上的家庭的话，"]},{"code":401,"indent":1,"parameters":["  可能无法负担呢。 」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「虽然人数很少，但是也有奖学金制度。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「相对的，在学院能够学习高程度的课程。"]},{"code":401,"indent":1,"parameters":["  毕业生当中也有几位知名的魔法使。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「想要在魔法协会就职也会变得更有利！」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「不过学校位于王国北部，"]},{"code":401,"indent":1,"parameters":["  与恶魔战争的最前线呢。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「实际上，经常会出现魔物呢……」"]},{"code":119,"indent":1,"parameters":["01"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[2,"关于课程"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「卡雷德尼魔法学院分为国中部与高中部。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「我们是高中部二年级呢。"]},{"code":401,"indent":1,"parameters":["  和一般学校一样，也有数学之类的课程喔。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「不过魔法课程才是主要，所以一般课程比较少。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「魔法课程是选修式的。要从魔法基础、"]},{"code":401,"indent":1,"parameters":["  诅咒魔法课程和仪式学等等之中选择。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「这是因为每个人擅长的魔法都不一样。"]},{"code":401,"indent":1,"parameters":["  就算学习没有天赋的魔法，也只会浪费时间而已。」"]},{"code":119,"indent":1,"parameters":["01"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[3,"关于社团"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「和一般学校一样有社团喔。"]},{"code":401,"indent":1,"parameters":["  当然也有人没加入社团就是了。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「虽然也有足球社之类的一般社团，"]},{"code":401,"indent":1,"parameters":["  不过我们学校没办法打进大会，所以不太受欢迎。」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「最受欢迎的是魔法研究会喔。"]},{"code":401,"indent":1,"parameters":["  不过那里不是谁都能加入的……」"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「其他还有很多魔法系的社团和研究会，"]},{"code":401,"indent":1,"parameters":["  所以不用担心。」"]},{"code":119,"indent":1,"parameters":["01"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[4,"没问题了"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>【汤米】"]},{"code":401,"indent":1,"parameters":["「那么，我来向你介绍一下霍华德宿舍吧。」"]},{"code":221,"indent":1,"parameters":[]},{"code":201,"indent":1,"parameters":[0,38,5,15,2,0]},{"code":122,"indent":1,"parameters":[1,1,0,0,10]},{"code":230,"indent":1,"parameters":[90]},{"code":222,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"sw
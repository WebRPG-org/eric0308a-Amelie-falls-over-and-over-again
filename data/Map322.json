1,"indent":0,"parameters":["不只是王在找丈夫，他也同样在找她。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["虽然丈夫吓得逃跑了，"]},{"code":401,"indent":0,"parameters":["但是对王的爱依然不变。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["他为了向妻子道歉并重新来过，一直在寻找妻子。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["就这样，两人破镜重圆。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["但是还有一个尚未解决的问题。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["那就是两人的小孩。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["虽然孩子被寄托在孤儿院，"]},{"code":401,"indent":0,"parameters":["但是夫妇去拜访时孩子却不在那里。"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["之后他们也一直在寻找，"]},{"code":401,"indent":0,"parameters":["但最后还是没有找到。"]},{"code":242,"indent":0,"parameters":[1]},{"code":235,"indent":0,"parameters":[30]},{"code":250,"indent":0,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……这样就结束了吗……？」"]},{"code":241,"indent":0,"parameters":[{"name":"rebiyatan","volume":60,"pitch":100,"pan":0}]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン レビヤタン f 中"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[027]"]},{"code":401,"indent":0,"parameters":["「是啊，毕竟是根据事实所写的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[028]"]},{"code":401,"indent":0,"parameters":["「不过话说回来……真是太好了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[029]"]},{"code":401,"indent":0,"parameters":["「看来吾并没有被抛弃。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳是指……？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[030]"]},{"code":401,"indent":0,"parameters":["「父母确实是爱着吾的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「莉薇坦……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「难道书上说的小孩……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[031]"]},{"code":401,"indent":0,"parameters":["「是啊，就是吾。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[032]"]},{"code":401,"indent":0,"parameters":["「真正的莉薇坦是吾的母亲。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[033]"]},{"code":401,"indent":0,"parameters":["「吾是恶魔之王和人类的混血儿。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[034]"]},{"code":401,"indent":0,"parameters":["「因为自称为王各方面来说都比较方便，"]},{"code":401,"indent":0,"parameters":["  所以吾才撒了谎。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[035]"]},{"code":401,"indent":0,"parameters":["「母亲成为人类时所使用的魔法，是继承魔法。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[036]"]},{"code":401,"indent":0,"parameters":["「那是将力量交给自己的孩子的魔法。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[037]"]},{"code":401,"indent":0,"parameters":["「就这样，吾在孤儿院的时候，"]},{"code":401,"indent":0,"parameters":["  突然得到了王的魔力，成为了完全的恶魔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「还有这种事……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[038]"]},{"code":401,"indent":0,"parameters":["「因为这股力量的关系，吾没办法继续待在孤儿院，"]},{"code":401,"indent":0,"parameters":["  所以才会四处旅行。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[039]"]},{"code":401,"indent":0,"parameters":["「吾以为被父母抛弃了，"]},{"code":401,"indent":0,"parameters":["  所以也没有去找他们。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[040]"]},{"code":401,"indent":0,"parameters":["「不过某一次，吾听说了这本小说，"]},{"code":401,"indent":0,"parameters":["  于是便想知道真相。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[041]"]},{"code":401,"indent":0,"parameters":["「吾听说最后一册就在这里，于是便潜入学院，"]},{"code":401,"indent":0,"parameters":["  却没想到会遇到这种事。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[042]"]},{"code":401,"indent":0,"parameters":["「不过，这样一来吾终于达成目的了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[043]"]},{"code":401,"indent":0,"parameters":["「你做得很好，正宗。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我也是，多亏有妳我才能拯救艾蜜莉。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我才要谢谢妳。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[044]"]},{"code":401,"indent":0,"parameters":["「嗯。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「但是，我还是无法置信。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳居然是恶魔和人类的混血儿，"]},{"code":401,"indent":0,"parameters":["  而且真正的恶魔之王已经不在了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[045]"]},{"code":401,"indent":0,"parameters":["「但是这一切都是事实。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[046]"]},{"code":401,"indent":0,"parameters":["「吾的确继承了莉薇坦的魔力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「这种事，我从魔法就能看出来。"]},{"code":401,"indent":0,"parameters":["  不過妳也有会被学生抓住这样粗心的一面呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[047]"]},{"code":401,"indent":0,"parameters":["「那、那是因为吾拥有回溯时间的魔法，"]},{"code":401,"indent":0,"parameters":["  所以才大意了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[048]"]},{"code":401,"indent":0,"parameters":["「吾被抓住之后睡了好几天，"]},{"code":401,"indent":0,"parameters":["  然后又等魔力恢复，结果超过了能够回溯的一个礼拜。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[049]"]},{"code":401,"indent":0,"parameters":["「吾继承的魔法只有几种而已，"]},{"code":401,"indent":0,"parameters":["  所以也不能硬闯出去。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[050]"]},{"code":401,"indent":0,"parameters":["「能够遇见正宗真是太好了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[051]"]},{"code":401,"indent":0,"parameters":["「然后……吾最后还有一件事想拜托你。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「还有什么事吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[052]"]},{"code":401,"indent":0,"parameters":["「吾想要补充魔力。因为吾消耗得太多了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[053]"]},{"code":401,"indent":0,"parameters":["「吾并没有打算做坏事，分点魔力给吾吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「补充魔力是指……咦……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 7
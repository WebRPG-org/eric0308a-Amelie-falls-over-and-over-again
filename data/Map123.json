ue,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":12,"y":2},{"id":3,"name":"とみ","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"7_6","direction":6,"pattern":1,"characterIndex":2},"list":[{"code":213,"indent":0,"parameters":[0,3,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「第一天上课怎么样？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「还挺有趣的。关于魔法，"]},{"code":401,"indent":0,"parameters":["  尽是一些我不知道的事情呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「毕竟自学是有极限的。"]},{"code":401,"indent":0,"parameters":["  一般的店也不会卖魔法的课本。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊，不过光是听课也有点无聊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「只是今天正好这样。"]},{"code":401,"indent":0,"parameters":["  也有会使用魔法的课程，放心吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「我很期待见识一下两位的实力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「别这么期待啦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「咦～」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「不过我以前都是一个人生活，"]},{"code":401,"indent":0,"parameters":["  很高兴现在有了室友呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我觉得一个人生活也挺自在的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「哈……我困了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「虽然离就寝还有一点时间，但就睡吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「一定是因为第一天上课，所以紧张而感到疲倦了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「或许是吧……」"]},{"code":250,"indent":0,"parameters":[{"name":"Decision2","volume":90,"pitch":100,"pan":0}]},{"code":213,"indent":0,"parameters":[0,1,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「啊……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯？」"]},{"code":213,"indent":0,"parameters":[0,6,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「那个……我还有一项规定没告诉你……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「这个……那个……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「有这么难开口吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「是啊……不过这是重要的规定，"]},{"code":401,"indent":0,"parameters":["  我必须告诉你才行……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「一般来说是入住宿舍的时候，"]},{"code":401,"indent":0,"parameters":["  会由学长告知……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（有这么严格的规定，让人连说出口都会犹豫吗……？）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「关、关于自慰的规定……」"]},{"code":213,"indent":0,"parameters":[-1,1,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「什么……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我还以为他要说什么呢，"]},{"code":401,"indent":0,"parameters":["  不过在集体生活中，这的确是无法忽视的问题。）」"]},{"code":213,"indent":0,"parameters":[0,6,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「这、这个……要是想自慰的话，"]},{"code":401,"indent":0,"parameters":["  就要告诉室友。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「被室友告知之后，"]},{"code":401,"indent":0,"parameters":["  就要暂时离开房间。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「所以……正宗要是想做的话，"]},{"code":401,"indent":0,"parameters":["  不用客气尽管跟我说！」"]},{"c
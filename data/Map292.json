ters":["SET_ANIME_Z 1"]},{"code":212,"indent":0,"parameters":[0,289,true]},{"code":356,"indent":0,"parameters":["SET_ANIME_Z 8"]},{"code":230,"indent":0,"parameters":[30]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 14"]},{"code":356,"indent":0,"parameters":["スキット スライドイン アメリ f 右2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[416]"]},{"code":401,"indent":0,"parameters":["「……！」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「没事吧？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[417]"]},{"code":401,"indent":0,"parameters":["「有很厉害的恶魔在……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「感觉这么强烈吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[418]"]},{"code":401,"indent":0,"parameters":["「嗯……是我从来没有感受过的魔力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「毕竟他得到了王的魔力，应该相当强大。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那么，位置在哪里？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[419]"]},{"code":401,"indent":0,"parameters":["「比这里，再上面一点……在社团楼层附近感觉到了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「昨天妳也是被带到社团楼层去对吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那边有他的据点吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 左"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[056]"]},{"code":401,"indent":0,"parameters":["「但是除了艾蜜莉以外什么也没有对吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[420]"]},{"code":401,"indent":0,"parameters":["「社团楼层还有地方没调查过吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「再去调查一次看看吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[421]"]},{"code":401,"indent":0,"parameters":["「嗯。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[057]"]},{"code":401,"indent":0,"parameters":["「话说，学生会长到底是什么人啊？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[058]"]},{"code":401,"indent":0,"parameters":["「除了副会长和杰克森学长以外，"]},{"code":401,"indent":0,"parameters":["  还有这么厉害的人啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那家伙是马汀家的人，"]},{"code":401,"indent":0,"parameters":["  据说他的祖先囚禁了莉薇坦。 」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「他的目的是得到莉薇坦的魔力，"]},{"code":401,"indent":0,"parameters":["  然后支配这个世界。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「现任的学生会长，"]},{"code":401,"indent":0,"parameters":["  似乎从莉薇坦身上夺走了许多力量。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我不知道他原本的实力，但是应该相当厉害。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[059]"]},{"code":401,"indent":0,"parameters":["「状况相当不妙啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊，所以已经没时间了。"]},{"code":401,"indent":0,"parameters":["  因为他会和我一起继承记忆，所以我不想再轮回了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[422]"]},{"code":401,"indent":0,"parameters":["「不过我已经知道学生会长的位置了。"]},{"code":401,"indent":0,"parameters":["  剩下的就只要打败他。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊。」"]},{"code":356,"indent":0,"parameters":["skit フェードアウト エレナ f"]},{"code":230,"indent":0,"parameters":[5]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン 日和 f 左"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[055]"]},{"code":401,"indent":0,"parameters":["「打败他之后，莉薇坦会怎么样呢？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[056]"]},{"code":401,"indent":0,"parameters":["「关于契约的事情，昨天没能听你详细解释。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「契约……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「使用时间回溯魔法的条件，"]},{"code":401,"indent":0,"parameters":["  是要我找出囚禁莉薇坦的犯人，并且打败他。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「所以只要打败学生会长，契约就完成了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[423]"]},{"code":401,"indent":0,"parameters":["「可是……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「囚禁莉薇坦的魔法结界也会消失。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 13"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[424]"]},{"code":401,"indent":0,"parameters":["「这样不太妙吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊。但是我认为莉薇坦不是那么邪恶的恶魔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我们一起相处了很长一段时间，"]},{"code":401,"indent":0,"parameters":["  她似乎对侵略没什么兴趣。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[057]"]},{"code":401,"indent":0,"parameters":["「恶魔说的话，真的能够相信吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「日和说得没错……"]},{"code":401,"indent":0,"parameters":["  但是，我想还是有沟通的可能。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「希望你们先相信我。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[058]"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[425]"]},{"code":401,"indent":0,"parameters":["「反正我们也不能拿恶魔之王怎么样。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[426]"]},{"code":401,"indent":0,"parameters":["「就算现在向勇者协会求助，"]},{"code":401,"indent":0,"parameters":["  要赶来也得花很多时间。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「莉薇坦的战斗能力，弱到会被学生抓住啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我想她应该没那么强。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[427]"]},{"code":401,"indent":0,"parameters":["「那回溯时间的魔法呢？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「因为发动要花时间，"]},{"code":401,"indent":0,"parameters":["  所以一旦进入战斗就无法使用。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「而且我能够继承记忆，"]},{"code":401,"indent":0,"parameters":["  不会让莉薇坦肆意妄为。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[059]"]},{"code":401,"indent":0,"parameters":["「……那我就先相信你。」"]},{"code":356
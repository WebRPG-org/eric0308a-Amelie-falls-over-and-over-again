meters":["スキット 表情 レビヤタン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[001]"]},{"code":401,"indent":0,"parameters":["「不用谢了。吾只是想试试刚复活的自己的力量。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳一击就打败了公爵级恶魔啊。"]},{"code":401,"indent":0,"parameters":["  相当厉害呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[002]"]},{"code":401,"indent":0,"parameters":["「那是因为他战斗之后相当疲劳了。"]},{"code":401,"indent":0,"parameters":["  而且才刚被召唤出来，魔力还不强。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[003]"]},{"code":401,"indent":0,"parameters":["「而且吾也只能使用那种攻击魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「这样啊……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[004]"]},{"code":401,"indent":0,"parameters":["「不用担心，吾才没有考虑侵略地表这种事。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[005]"]},{"code":401,"indent":0,"parameters":["「吾只要达成目的后，就会再次从台面上消失了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳的目的是什么？"]},{"code":401,"indent":0,"parameters":["  结果妳还是没有告诉我。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[006]"]},{"code":401,"indent":0,"parameters":["「也没什么好隐瞒的，你听好啰。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[007]"]},{"code":401,"indent":0,"parameters":["「吾正在寻找一部小说。"]},{"code":401,"indent":0,"parameters":["  一个恶魔之王与人类坠入爱河的故事。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那就是妳的目的？等等……我有啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[008]"]},{"code":401,"indent":0,"parameters":["「什么？让吾看看。」"]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":4,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「就是这三本。我在学院里偶然发现的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[009]"]},{"code":401,"indent":0,"parameters":["「这是……吾的书。"]},{"code":401,"indent":0,"parameters":["  是吾被关进监狱里时被没收的书。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[010]"]},{"code":401,"indent":0,"parameters":["「没事真是太好了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「但是妳在找的应该不是这个吧？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[011]"]},{"code":401,"indent":0,"parameters":["「嗯。这部小说一共有四册。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[012]"]},{"code":401,"indent":0,"parameters":["「吾听说最后一册就在这里的大图书馆的禁书库里面，"]},{"code":401,"indent":0,"parameters":["  所以就来找了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[013]"]},{"code":401,"indent":0,"parameters":["「吾想到终于能够把书拿到手，"]},{"code":401,"indent":0,"parameters":["  太兴奋了才会被抓住。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「只是在找小说而已啊。"]},{"code":401,"indent":0,"parameters":["  我还担心妳有什么企图呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[015]"]},{"code":401,"indent":0,"parameters":["「这不只是一般的小说。"]},{"code":401,"indent":0,"parameters":["  而是记录了实际发生的事情的书。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[50]\\z[016]"]},{"code":401,"indent":0,"parameters":["「你看过书的内容了吗？」"]},{"code":102,"indent":0,"parameters":[["再看一次","我记得内容"],1,-1,1,0]},{"code":402,"indent":0,"parameters":[0,"再看一次"]},{"code":250,"indent":1,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":231,"indent":1,"parameters":[30,"h01",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["在我诞生的许久以前，"]},{"code":401,"indent":1,"parameters":["恶魔之王被暗中召唤了出来。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["然而，即使以数量庞大的活祭品发动了召唤仪式，"]},{"code":401,"indent":1,"parameters":["使恶魔之王来到地面上，王却离开了军队。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["尽管属下的恶魔请王留步，"]},{"code":401,"indent":1,"parameters":["王却表示对侵略地面没兴趣而拒绝了。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["之后，王再也没有出现在苍蝇骑士团面前。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["人类听到王已被召唤出来的传言，感到惊恐害怕，"]},{"code":401,"indent":1,"parameters":["但是恶魔却没有进攻的迹象。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["就这样经过了漫长的时光，"]},{"code":401,"indent":1,"parameters":["不知不觉中，王的存在被世人所遗忘。"]},{"code":250,"indent":1,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":1,"parameters":[60]},{"code":231,"indent":1,"parameters":[30,"h02",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["恶魔之王藏起角、尾巴与翅膀，"]},{"code":401,"indent":1,"parameters":["化作人类的样貌在地面生活。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["她原本就无意侵略，"]},{"code":401,"indent":1,"parameters":["而是对地面有兴趣才让属下召唤出来的。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["就这样，王非常中意人类的文化，"]},{"code":401,"indent":1,"parameters":["在古德兰王国的乡下小镇住了下来。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["人们完全没有怀疑她是恶魔，"]},{"code":401,"indent":1,"parameters":["有一名男人爱上了这位端庄美丽的王。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["王也被男人的诚实与勇敢所打动，"]},{"code":401,"indent":1,"parameters":["两人很快就结为了夫妻。"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["但是，王依旧怀抱着绝对不能暴露的秘密，"]},{"code":401,"indent":1,"parameters":["那就是自己是一名恶魔。"]},{"code":250,"indent":1,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":1,"parameters":[60]},{"code":231,"indent":1,"parameters":[30,"h03",0,0,0,0,100,100,255,0]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["王和人类的婚姻生活一帆风顺，
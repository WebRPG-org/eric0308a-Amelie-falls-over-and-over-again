meters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[020]"]},{"code":401,"indent":0,"parameters":["「啊、嗯……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那么，妳怎么想呢？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[021]"]},{"code":401,"indent":0,"parameters":["「我也……喜欢你……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（虽然已经知道了，但是不管听到几次都很开心呢。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 14"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[022]"]},{"code":401,"indent":0,"parameters":["「哇～好难为情……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「抱歉，忽然说这种话……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「但是我不希望妳被人抢走。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[023]"]},{"code":401,"indent":0,"parameters":["「你太爱操心了啦。我又不是那么轻浮的女人。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊……不过我还是想告诉妳。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[024]"]},{"code":401,"indent":0,"parameters":["「嗯……谢谢你。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（真是太好了……）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 19"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[025]"]},{"code":401,"indent":0,"parameters":["「这表示……我们交往了对吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯，如果妳同意的话。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[026]"]},{"code":401,"indent":0,"parameters":["「我没问题唷。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 19"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[027]"]},{"code":401,"indent":0,"parameters":["「那么……以后请多多指教啰。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（太好了……这样就再次和艾蜜莉交往了。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（当然，还不能够大意。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那么，今天就先回房间去吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[028]"]},{"code":401,"indent":0,"parameters":["「就这样……结束了吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「不，虽然我也想做…但毕竟是宿舍。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[029]"]},{"code":401,"indent":0,"parameters":["「你说想做是指……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「当然是色色的事……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 20"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[030]"]},{"code":401,"indent":0,"parameters":["「不是啦！我才没有那种想法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「咦……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 19"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[031]"]},{"code":401,"indent":0,"parameters":["「我说的是接吻之类的……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「啊，这样啊……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（果然没了媚药就完全不一样啊。"]},{"code":401,"indent":0,"parameters":["  太好了。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[032]"]},{"code":401,"indent":0,"parameters":["「别傻笑啦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「呵呵，那就来接吻吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[033]"]},{"code":401,"indent":0,"parameters":["「总觉得有点讨厌。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「别这么说嘛。」"]},{"code":356,"
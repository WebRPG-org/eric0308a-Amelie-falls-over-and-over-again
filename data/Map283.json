",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[310]"]},{"code":401,"indent":0,"parameters":["「而且我也有错。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「没这回事，我说了讨厌的话。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「就算计较过去的事情也没意义啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「真的很对不起……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[311]"]},{"code":401,"indent":0,"parameters":["「嗯……我也要跟你道歉。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[312]"]},{"code":401,"indent":0,"parameters":["「明明有正宗了，我还跟别人……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「没办法……毕竟进到了那种地城里面啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「还有触手那件事……也是必须要做的对吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[313]"]},{"code":401,"indent":0,"parameters":["「我都表现出那个样子了，你还愿意喜欢我啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那当然。无论变成怎样，妳就是妳啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那件衣服的魔法道具，如果是妳考虑过后才决定要穿，"]},{"code":401,"indent":0,"parameters":["  那我不会再多说什么了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「只是，我很讨厌被人看見妳的裸体。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[314]"]},{"code":401,"indent":0,"parameters":["「这件事我觉得很抱歉。"]},{"code":401,"indent":0,"parameters":["  不过也只有现在会穿而已。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[315]"]},{"code":401,"indent":0,"parameters":["「只要魔力恢复原来​​的状况，我就不会再穿了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（她会毫无反抗就穿上那种衣服，"]},{"code":401,"indent":0,"parameters":["  原因在于我的轮回。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我也没办法单方面责怪她。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「最后……我能亲妳吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[316]"]},{"code":401,"indent":0,"parameters":["「当然可以。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[317]"]},{"code":401,"indent":0,"parameters":["「因为正宗是我的男朋友嘛。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 22"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[318]"]},{"code":401,"indent":0,"parameters":["「嗯……啾……啾……」"]},{"code":101,"indent":0,"para
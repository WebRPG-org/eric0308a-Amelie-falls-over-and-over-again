e":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「原来如此……那叫做岩魔法不就好了？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「这样情报量太少了，很难想像呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「我希望是用岩石来破坏那种感觉的名字。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「你说得对。那么……岩石崩坏冲击之类的呢？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「噗……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「喂！你笑了吧！」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「哎呀，抱歉抱歉。我觉得很帅气喔。"]},{"code":401,"indent":0,"parameters":["  呵呵……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「什、什么……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「我也觉得很不错喔……噗……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「连汤米都这样。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 3"]},{"code":356,"indent":0,"parameters":["スキット スライドイン レオン f 左"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「老实说……太俗气了吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「哈哈……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「你、你们……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「大家为什么要笑啊。"]},{"code":401,"indent":0,"parameters":["  他可是拼命想出来的啊，呵呵……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「（他很自然地嘲讽我……）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「不过实际上，真的有人会把魔法取成令人尴尬的名字呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「只要本人容易想像就好了吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「是没错啦，但是之前有人把上级炎魔法的名字说得超级长，"]},{"code":401,"indent":0,"parameters":["  害我差点笑出来。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「战斗中没有时间咏唱吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「（我本来想把上级炎魔法的名字取成魔炎弹，"]},{"code":401,"indent":0,"parameters":["  难道这样很俗气吗……？）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「虽然以前这种魔法很多，"]},{"code":401,"indent":0,"parameters":["  但是最近都没有了吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「基本上有魔法级别和种类就没问题了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0
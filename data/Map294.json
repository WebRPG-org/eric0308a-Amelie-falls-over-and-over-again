":401,"indent":0,"parameters":["「目的是为了让我进入轮回。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「你在说什么？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「能够办到这件事的……」"]},{"code":102,"indent":0,"parameters":[["「只有当时在教室里的人。」"],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"「只有当时在教室里的人。」"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[30,"01",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[120]},{"code":235,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「你说什么……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「在前段时间的诅咒魔法课上，"]},{"code":401,"indent":0,"parameters":["  有一次要用到姓名。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「因为要用本名，所以用假名的学生没办法出席吧。」"]},{"code":102,"indent":0,"parameters":[["「那个时候，你为什么不在？」"],-1,0,1,0]},{"code":402,"indent":0,"parameters":[0,"「那个时候，你为什么不在？」"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":231,"indent":0,"parameters":[30,"02",0,0,0,0,100,100,255,0]},{"code":230,"indent":0,"parameters":[120]},{"code":235,"indent":0,"parameters":[30]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【汤米】"]},{"code":401,"indent":0,"parameters":["「前段时间是什么意思啊。我不知道啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「学生会长放了信在我的房间里。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"
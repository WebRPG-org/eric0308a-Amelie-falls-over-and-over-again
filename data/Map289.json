ent":0,"parameters":["スキット 表情 日和 f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[048]"]},{"code":401,"indent":0,"parameters":["「在会长室里，学生会长知道正宗同学的名字。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[049]"]},{"code":401,"indent":0,"parameters":["「还说了一些耐人寻味的话。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「那只是因为……对方单方面知道我是谁吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[050]"]},{"code":401,"indent":0,"parameters":["「不只这样，我还听见了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[051]"]},{"code":401,"indent":0,"parameters":["「我听见你小声说着莉薇坦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「唔……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 13"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[052]"]},{"code":401,"indent":0,"parameters":["「莉薇坦是恶魔之王的其中一人。"]},{"code":401,"indent":0,"parameters":["  你当时为什么会说出她的名字？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「应该……是妳听错了吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[053]"]},{"code":401,"indent":0,"parameters":["「这种随便的借口，"]},{"code":401,"indent":0,"parameters":["  反而让我更加怀疑你了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（糟糕……怎么办……？"]},{"code":401,"indent":0,"parameters":["  我该说什么才好？）」"]},{"code":356,"indent":0,"parameters":["skit フェードアウト アメリ f"]},{"code":230,"indent":0,"parameters":[5]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン エレナ f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[051]"]},{"code":401,"indent":0,"parameters":["「我……我也觉得正宗怪怪的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[052]"]},{"code":401,"indent":0,"parameters":["「该怎么说呢，感觉好像不是第一次见面一样。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[23]\\z[053]"]},{"code":401,"indent":0,"parameters":["「遇到正宗的时候，心中擅自涌现了陌生的感情。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【日和】\\m[32]\\z[054]"]},{"code":401,"indent":0,"parameters":["「我也有印象。」"]},{"code":356,"indent":0,"parameters":["skit フェードアウト エレナ f"]},{"code":230,"indent":0,"parameters":[5]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン オリビア f 右"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[41]\\z[156]"]},{"code":401,"indent":0,"parameters":["「这么说来，他用了只有学生会知道的传送魔法。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[41]\\z[157]"]},{"code":401,"indent":0,"parameters":["「虽然他说是从毕业生那边听来的，但果然还是很奇怪。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 オリビア f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【奥莉薇亚】\\m[41]\\z[158]"]},{"code":401,"indent":0,"parameters":["「我不认为皇国出身的你会认识毕业生。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我……我只是为了阻止召唤恶魔而来的。」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":230,"indent":0,"parameters":[5]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「对吧艾蜜莉。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":356,"indent":0,"parameters":["スキット スライドイン アメリ f 右2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[352]"]},{"code":401,"indent":0,"parameters":["「嗯……正宗不可能和恶魔有关系。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[353]"]},{"code":401,"indent":0,"parameters":["「但是，从前阵子开始我就觉得有点奇怪。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「艾蜜莉……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[354]"]},{"code":401,"indent":0,"parameters":["「因为你一来到学院之后，就忽然变得很强。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[355]"]},{"code":401,"indent":0,"parameters":["「而且……我在你身上感觉到有点奇怪的气息。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「你说什么……？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[356]"]},{"code":401,"indent":0,"parameters":["「最近，有时候会感觉到一股邪恶的魔力。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[357]"]},{"code":401,"indent":0,"parameters":["「因为学院里有很多魔物，我本来以为是这个原因，"]},{"code":401,"indent":0,"parameters":["  但是我和正宗待在一起的时候才会感受到。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[358]"]},{"code":401,"indent":0,"parameters":["「如果有事情隐瞒的话，希望你告诉我。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[359]"]},{"code":401,"indent":0,"parameters":["「我不认为正宗会做坏事。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[10]\\z[360]"]},{"code":401,"indent":0,"parameters":["「如果遇到麻烦的话，我想要助你一臂之力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「艾蜜莉……谢谢妳。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我以为告诉她真相的话，会被她讨厌……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（可是……艾蜜莉还是会担心我。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我也要更相信她才行。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameter
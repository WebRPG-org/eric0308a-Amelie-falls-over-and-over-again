,"parameters":["スキット 表情 レビヤタン f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[061]"]},{"code":401,"indent":0,"parameters":["「而且还一边小声念着艾蜜莉的名字。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳这不是看得很清楚吗！」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[062]"]},{"code":401,"indent":0,"parameters":["「只有两次而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「第二次可以避开吧！」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「喂，妳别再偷看了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[063]"]},{"code":401,"indent":0,"parameters":["「你才是，别秀给吾看啦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我才没有秀给妳看。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[064]"]},{"code":401,"indent":0,"parameters":["「好啦，知道了知道了。话说完了就快滚。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[065]"]},{"code":401,"indent":0,"parameters":["「吾很困了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「喔……啊，我又不是来叫妳别看我自慰的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是关于妳的魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「和上次的轮回相比，我变得更强了。"]},{"code":401,"indent":0,"parameters":["  虽然保有战斗经验的记忆也有影响，但是不只这样。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「单纯是魔法的威力和精准度提升了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「这是怎么回事？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[066]"]},{"code":401,"indent":0,"parameters":["「喔，吾没有和你详细说明呢。"]},{"code":401,"indent":0,"parameters":["  吾想说你不知道也没关系。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[067]"]},{"code":401,"indent":0,"parameters":["「也不是什么需要隐瞒的事，吾就告诉你吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[068]"]},{"code":401,"indent":0,"parameters":["「吾的回溯时间的魔法，"]},{"code":401,"indent":0,"parameters":["  能够将一切的现象还原，并且将时间回溯。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[069]"]},{"code":401,"indent":0,"parameters":["「但是也有不会还原的事物。"]},{"code":401,"indent":0,"parameters":["  那就是吾，还有受吾魔力影响之人。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「魔力的影响是指什么？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【莉薇坦】\\m[45]\\z[070]"]},{"code":401,"indent":0,"
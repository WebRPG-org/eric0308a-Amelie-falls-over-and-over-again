rs":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（仔细想想，我根本不知道亲近女孩子的方法。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我根本没和艾蜜莉以外的女生好好说过话。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【班上的辣妹】"]},{"code":401,"indent":0,"parameters":["「艾莲娜真受欢迎，好羡慕喔～」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[005]"]},{"code":401,"indent":0,"parameters":["「你绝对没这么想吧。话说，你的目的是什么？」"]},{"code":205,"indent":0,"parameters":[1,{"list":[{"code":19,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":19,"indent":null}]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[006]"]},{"code":401,"indent":0,"parameters":["「该不会是看上我的身体了吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我怎么可能会想看……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 11"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[007]"]},{"code":401,"indent":0,"parameters":["「呵呵，总觉得像是处男的反应。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这家伙，到底要笑我是处男多少次才满意啊……）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我才不是处男。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[008]"]},{"code":401,"indent":0,"par
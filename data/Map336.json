":["  「你是处男吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「……干嘛忽然问这个？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「没有啦，我很好奇。所以呢？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「我不想回答。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「那就是处男啰。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「别擅自下结论啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「那么汤米呢？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「我、我吗！？这个……"]},{"code":401,"indent":0,"parameters":["  我没有交过女朋友。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「汤米也是啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「你在问什么啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「没有啦……因为室友跟我说他昨天做爱了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["「他说中出的快感很爽，"]},{"code":401,"indent":0,"parameters":["  我才想知道是怎么样的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「这是该在上课时间问的事吗……"]},{"code":401,"indent":0,"parameters":["  不过这样的话，你问莱昂不就好了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 3"]},{"code":356,"indent":0,"parameters":["スキット スライドイン レオン f 左"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「叫我吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「是这样没错，但这家伙很受欢迎，"]},{"code":401,"indent":0,"parameters":["  所以我有点不甘心。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「再怎么说我的自尊还是不允许。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「把那种自尊丢掉啦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「算了，就问莱昂吧。"]},{"code":401,"indent":0,"parameters":["  所以，到底是什么感觉？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 7"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「嗯～我想想，很难用言语说明呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「举例来说，很接近第一次使用魔法的感觉吧。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「什么！？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 3"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「自己体内的魔力，咻地往外射出对吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レオン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「第一次经历那个的时候，真的很厉害呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「啊～我好像有点明白了。非常舒服呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「把魔力说得像是精液一样……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「原来如此，像第一次使用魔法时的感觉啊……​​」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「嗯……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「怎么了，你还是不太明白吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「也是啦，毕竟第一次使用魔法，"]},{"code":401,"indent":0,"parameters":["  可能对有些人来说是心理创伤呢。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「如果是难受的回忆，还是别想起来比较好。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「不是啦，我第一次使用的魔法，"]},{"code":401,"indent":0,"parameters":["  是把养的猫变身成色情模样的魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「因为那模样让我兴奋到射了，"]},{"code":401,"indent":0,"parameters":["  所以根本就不记得魔法的感觉。」"]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":230,"indent":0,"parameters":[5]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「（这家伙比想像中还不妙啊。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 9"]},{"cod
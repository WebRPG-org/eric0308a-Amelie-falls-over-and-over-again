eters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（她怎么会知道……？）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 42"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[104]"]},{"code":401,"indent":0,"parameters":["「你不回答我也行。"]},{"code":401,"indent":0,"parameters":["  不过嘛，看你的反应就都知道了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳到底是……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 31"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[105]"]},{"code":401,"indent":0,"parameters":["「放心吧，我不打算通知学院。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[106]"]},{"code":401,"indent":0,"parameters":["「不如说，我是来监视学院的那种人。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「监视……这话怎么说？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 42"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[107]"]},{"code":401,"indent":0,"parameters":["「正宗你是派得上用场的人，我就告诉你吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[108]"]},{"code":401,"indent":0,"parameters":["「我是皇国的间谍。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「间谍……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我就觉得她不是一般的学生，"]},{"code":401,"indent":0,"parameters":["  没想到居然是皇国送进来的人。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「皇国打算和古德兰王国敌对吗……？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 43"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[109]"]},{"code":401,"indent":0,"parameters":["「没有那么夸张啦。"]},{"code":401,"indent":0,"parameters":["  我只负责将情报送回国内而已。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 32"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[110]"]},{"code":401,"indent":0,"parameters":["「不管哪个国家都有这种人。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[111]"]},{"code":401,"indent":0,"parameters":["「再说我也不是伪造年纪入学的，"]},{"code":401,"indent":0,"parameters":["  是透过正常管道。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这家伙……到底知道了多少情报？）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[112]"]},{"code":401,"indent":0,"parameters":["「魔法学院的情报很难流传到外面。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 31"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[113]"]},{"code":401,"indent":0,"parameters":["「所以皇帝陛下直接下令，"]},{"code":401,"indent":0,"parameters":["  要我收集学院里的情报。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「原来如此……所以你才会调查我们的事情。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 43"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[114]"]},{"code":401,"indent":0,"parameters":["「转学生什么的看起来就很可疑，"]},{"code":401,"indent":0,"parameters":["  真亏学院能够允许。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「似乎是勇者协会努力过了……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「话说回来，皇帝陛下亲自指名妳……"]},{"code":401,"indent":0,"parameters":["原来妳其实是这么厉害的人啊。 」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「对我来说，皇帝陛下就是高高在上的存在。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[115]"]},{"code":401,"indent":0,"parameters":["「这没什么，只是因为贺茂家代代效忠皇帝陛下。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 31"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[116]"]},{"code":401,"indent":0,"parameters":["「因此我从小就接受训练。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「从小接受训练啊……妳们也真是辛苦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（话说回来，双重人格和这件事有关吗……？）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[117]"]},{"code":401,"indent":0,"parameters":["「这个话题就到此为止。"]},{"code":401,"indent":0,"parameters":["  已经知道彼此的真面目了，让我们适度地合作吧。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 44"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[118]"]},{"code":401,"indent":0,"parameters":["「绝不能让人召唤或研究恶魔。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[119]"]},{"code":401,"indent":0,"parameters":["「要是古德兰王国惨遭恶魔的毒手，"]},{"code":401,"indent":0,"parameters":["  接下来说不定就轮到皇国了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「这件事一定要避免。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 42"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[120]"]},{"code":401,"indent":0,"parameters":["「呵呵，你真的这么想吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……这个嘛，老实说我没有多爱国。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[121]"]},{"code":401,"indent":0,"parameters":["「我想也是。毕竟学院里的人，"]},{"code":401,"indent":0,"parameters":["  大多都是经历过惨痛的回忆而入学的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 31"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[122]"]},{"code":401,"indent":0,"parameters":["「只要不和皇国敌对，我就不会多说什么。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 36"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[123]"]},{"code":401,"indent":0,"parameters":["「当然，要是做出危害到皇帝陛下的举动，"]},{"code":401,"indent":0,"parameters":["  无论是谁我都不会饶恕。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「我和勇者协会都没有这种想法。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 41"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[124]"]},{"code":401,"indent":0,"parameters":["「那就好。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 日和 f 42"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【小夜子】\\m[35]\\z[125]"]},{"code":401,"indent":0,"parameters":["「那么我要回房间去了，明天见。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「嗯，掰掰。」"]},{"code":221,"indent":0,"parameters":[]},{"code":356,"indent":0,"parameters":["スキット 終了"]},{"code":242,"indent":0,"parameters":[1]},{"code":230,"indent":0,"parameters":[120]},{"code":201,"indent":0,"parameters":[0,238,8,9,0,0]},{"code":222,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":6,"y":10},null,{"id":4,"name":"EV004","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":53,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":83},"directionFix":true,"image":{"tileId":0,"characterName":"!fsm_Flame16","direction":8,"pattern":1,"characterIndex":5},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":7,"y":8},null,null,null,null,null,null,null,null,null,null,null,null,null,null,null]}
101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「和一般的攻击魔法和治愈魔法不一样，"]},{"code":401,"indent":0,"parameters":["  能够改变世界的魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「我要得到那种魔法。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「然后导正这个错误的世界。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 9"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「为了这个目的，和恶魔订下契约是最快的捷径。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[066]"]},{"code":401,"indent":0,"parameters":["「你的做法是错的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[067]"]},{"code":401,"indent":0,"parameters":["「反对魔法的人并不是敌人。"]},{"code":401,"indent":0,"parameters":["  要是订下契约的话，你会变成恶魔啊。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「没关系，只要能够达成目的。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「我会挺身战斗。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「和你们这些只会抱怨却什么都不做的人不一样。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[145]"]},{"code":401,"indent":0,"parameters":["「艾莲娜……也会战斗。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「妳？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[146]"]},{"code":401,"indent":0,"parameters":["「我知道我不像杰克森学长那样有天赋，"]},{"code":401,"indent":0,"parameters":["  但是我必须阻止你才行。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 5"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾莲娜】\\m[19]\\z[147]"]},{"code":401,"indent":0,"parameters":["「召唤恶魔有多么危险，艾莲娜最清楚了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「那是因为魔力低下的人召唤才会那样。"]},{"code":401,"indent":0,"parameters":["  我能够控制得住。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 エレナ f 6"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[068]"]},{"code":401,"indent":0,"parameters":["「可是，你没有和真正的恶魔战斗过吧？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[069]"]},{"code":401,"indent":0,"parameters":["「要是失败的话该怎么办？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「要是连一只恶魔都无法控制，"]},{"code":401,"indent":0,"parameters":["  就无法改变世界了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「失败之后的事情怎样都无所谓。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[070]"]},{"code":401,"indent":0,"parameters":["「真会给人添麻烦。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「说够了吧。我要阻止你的计划。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我也一样，达成目的之后就要打败莉薇坦。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（我只是因为利害关系一致而协助她，"]},{"code":401,"indent":0,"parameters":["  但我们毕竟是敌人，这是当然的。）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[071]"]},{"code":401,"indent":0,"parameters":["「嗯，要上啰正宗！」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「嘿嘿……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[072]"]},{"code":401,"indent":0,"parameters":["「你在笑什么……？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「什么啊，艾蜜莉也要战斗吗？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[073]"]},{"code":401,"indent":0,"parameters":["「那当然啰。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「我还以为妳肯定会站在我这边呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 12"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[074]"]},{"code":401,"indent":0,"parameters":["「……那怎么可能。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「是啊，为什么艾蜜莉要帮你啊？」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「这个嘛……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 13"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[075]"]},{"code":401,"indent":0,"parameters":["「说够了吧……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「艾蜜莉……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「什么啊，妳不想被他听见吗？"]},{"code":401,"indent":0,"parameters":["  明明在我面前这么诚实呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[076]"]},{"code":401,"indent":0,"parameters":["「正宗，你不要听他乱说。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「啊、啊……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（为什么她这么慌张……？"]},{"code":401,"indent":0,"parameters":["  不，没必要去想这种事。）」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「（这个轮回的艾蜜莉也……）」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 1"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「什么都不知道就被我杀掉也很可怜。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「我就全部告诉你吧。在你为了打败我而努力的期间，"]},{"code":401,"indent":0,"parameters":["  艾蜜莉一直在和我做爱呢。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 13"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[077]"]},{"code":401,"indent":0,"parameters":["「别、别说了……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 2"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「口交真的很爽呢。虽然一开始很笨拙，"]},{"code":401,"indent":0,"parameters":["  但是我教会她之后，很快就擅长起来了。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 アメリ f 20"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[5]\\z[078]"]},{"code":401,"indent":0,"parameters":["「才不是……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 ジャクソン f 10"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【杰克森】"]},{"code":401,"indent":0,"parameters":["「第一次做爱的时候好像还哭了呢。"]},{"code":401,"indent":0,"parameters":["  不过被乱交中出，这也没办法。」"]},{"c
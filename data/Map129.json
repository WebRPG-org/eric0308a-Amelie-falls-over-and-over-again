"indent":0,"parameters":["「……妳也是吗？」"]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[133]"]},{"code":401,"indent":0,"parameters":["「嗯……我家也没有宽裕到能够就读学院。」"]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":17,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":17,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[134]"]},{"code":401,"indent":0,"parameters":["「好了，消极的话题就说到这里，我带你参观宿舍。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[135]"]},{"code":401,"indent":0,"parameters":["「我是这里最厉害的大姐姐，"]},{"code":401,"indent":0,"parameters":["  所以我会告诉你很多事情。」"]},{"code":213,"indent":0,"parameters":[0,2,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「妳是最厉害的？这支部队没问题吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[136]"]},{"code":401,"indent":0,"parameters":["「真是狂妄啊。我对施展魔法很有自信喔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[137]"]},{"code":401,"indent":0,"parameters":["「刚才我也一发就打败你没办法打败的魔物了吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"indent":0,"parameters":["「确实……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【艾蜜莉】\\m[1]\\z[138]"]},{"code":401,"indent":0,"parameters":["「呵呵，你可以把我当作姐姐依赖我喔。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\>【正宗】"]},{"code":401,"
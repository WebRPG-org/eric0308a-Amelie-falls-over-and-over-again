0,"parameters":["  「只是利用了原本就有的地城而已。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["  「因为我们掌握了魔女四人众入侵的消息，"]},{"code":401,"indent":0,"parameters":["  所以才设下了诱捕的陷阱。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【梅丽莎老师】"]},{"code":401,"indent":0,"parameters":["  「毕竟她们总是在收集这种魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「精力旺盛魔法果然……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【校长】"]},{"code":401,"indent":0,"parameters":["  「才没有那种魔法。」"]},{"code":213,"indent":0,"parameters":[3,7,false]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【莱昂】"]},{"code":401,"indent":0,"parameters":["  「真遗憾……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【校长】"]},{"code":401,"indent":0,"parameters":["  「我们本来想自己抓住卡雷德尼出身的她，"]},{"code":401,"indent":0,"parameters":["  不过似乎全都被她看穿了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【校长】"]},{"code":401,"indent":0,"parameters":["  「总之，你们没事真是太好了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【校长】"]},{"code":401,"indent":0,"parameters":["  「阿尔伯特同学也没事吧？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「他的身体好像没事……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「没想到你居然就是阿尔伯特王子。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「因为要是被人发现是王子，各方面都很麻烦啊。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"co
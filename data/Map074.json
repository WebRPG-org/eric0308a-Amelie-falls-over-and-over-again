,"indent":0,"parameters":["【汉娜】"]},{"code":401,"indent":0,"parameters":["  「怎么忽然这么说……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 6"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汉娜】"]},{"code":401,"indent":0,"parameters":["  「别说蠢话了。"]},{"code":401,"indent":0,"parameters":["  你不是为了拯救艾蜜莉，才这么拼命的吗。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「至今为止我都没有考虑其他事情，一直在拼命努力。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「因为艾蜜莉一开始和我交往……"]},{"code":401,"indent":0,"parameters":["  所以我才想要拼命挽回最爱的她。」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 4"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汉娜】"]},{"code":401,"indent":0,"parameters":["  「……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「虽然到了最后，艾蜜莉的态度让我有点意见……"]},{"code":401,"indent":0,"parameters":["  不过那也是我害的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「她变成了快感的俘虏……"]},{"code":401,"indent":0,"parameters":["  都是因为我反覆进行轮回。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「因为一开始被魔犬击败之后，"]},{"code":401,"indent":0,"parameters":["　　被霍夫曼施了魔法……」"]},{"code":356,"indent":0,"parameters":["スキット 表情 レビヤタン f 8"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汉娜】"]},{"code":401,"indent":0,"parameters":["  「你别太责怪自己了……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「我并不是讨厌艾蜜莉。"]},{"code":401,"indent":0,"parameters":["   只是，我认为还是离开彼此比较好。」"]},{"code":356,"inde
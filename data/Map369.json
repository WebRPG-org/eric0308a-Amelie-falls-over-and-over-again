":["  「是吗。但是这里就是通道的终点了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「那边的梯子连接着女生宿舍的房间。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「虽然现在是空房间，"]},{"code":401,"indent":0,"parameters":["  但是你们进去的话可就不能善罢甘休了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「真的只是通道而已吗……？"]},{"code":401,"indent":0,"parameters":["  要是有做出偷窥孔就好了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「什么！这个男的……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「抱歉打扰妳了。我们要回去了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「话说回来，妳为什么要在这种地方研究啊？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「想做魔法研究的话，在学院里的设施也能进行吧？」"]},{"code":241,"indent":0,"parameters":[{"name":"scene_siriasu2","volume":60,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「这个……因为我研究的是让人能够使用魔法的道具。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「是指魔法道具吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「和以往的魔法道具不一样。"]},{"code":401,"indent":0,"parameters":["  现在的魔法道具是用来协助施法的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「而我制作的是能够发出魔法的道具。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「只要使用这个道具，谁都能够使用魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【汤米】"]},{"code":401,"indent":0,"parameters":["  「真厉害！这样一般人也能够使用了。」"]},{"code":401,"indent":0,"parameters":["  」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「不过……萨缪尔教会不可能认同这种道具。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「就算是这样……我也要把它完成。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「只要试着使用魔法，"]},{"code":401,"indent":0,"parameters":["  一定能够明白魔法的美妙。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「这样一来，祖国的人们也会认同魔法了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【正宗】"]},{"code":401,"indent":0,"parameters":["  「祖国……有什么原因吗？」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「有是有，但不能告诉你们。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【骷髅假面】"]},{"code":401,"indent":0,"parameters":["  「机会难得，就告诉我们嘛。"]},{"code":401,"indent":0,"parameters":["  反正妳都说这么多了。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「算了，你们想知道的话那好吧。"]},{"code":401,"indent":0,"parameters":["　　这在我的祖国是人尽皆知的事。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「我出生长大的普鲁士王国，"]},{"code":401,"indent":0,"parameters":["  几乎所有国民都是萨缪尔教徒。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「所以非常排斥魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「只要在人前使用魔法，立刻就会被通报教会。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「连皇家的人也不例外。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「有一次，普鲁士王国的第一王子，"]},{"code":401,"indent":0,"parameters":["  不小心在人前使用了魔法。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「传闻很快就什嚣尘上，"]},{"code":401,"indent":0,"parameters":["  王子受到了国民的强烈抨击。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「而受到打击的王子，"]},{"code":401,"indent":0,"parameters":["  从那以后就一直关在城里足不出户。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「本来勇敢又聪明的王子，"]},{"code":401,"indent":0,"parameters":["  就只是因为使用了魔法……」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「这种事情是不能允许的。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["【席维斯・冯・拜修维克】"]},{"code":401,"indent":0,"parameters":["  「所以我要让国民认同魔法，"]},{"code":401,"indent":0,"parameters":["  让王子恢复原本的精神。」"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{